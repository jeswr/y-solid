# Supply-chain hardening (suite default — see prod-solid-server ADR-0011):
# disable npm install/lifecycle scripts so no fetched package can run a
# postinstall/preinstall/prepare payload. Consumers installing this package
# via `npm install github:jeswr/y-solid#main` therefore need NO build step —
# the built `dist/` is committed (see README + scripts/check-dist.mjs).
ignore-scripts=true
